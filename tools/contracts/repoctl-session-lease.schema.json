{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tools/contracts/repoctl-session-lease.schema.json",
  "title": "Repoctl Task Session Lease",
  "x-canonical-cli-surface": [
    "omta-repoctl task session acquire",
    "omta-repoctl task session heartbeat",
    "omta-repoctl task session release",
    "omta-repoctl task status"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "repository",
    "task_id",
    "session_id",
    "holder_agent_id",
    "mode",
    "phase",
    "state",
    "lease_started_at",
    "last_heartbeat_at",
    "lease_expires_at",
    "claimed_commit_units",
    "claimed_scope_keys",
    "claimed_hot_roots",
    "claimed_resource_claims"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "holder_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["writer", "observer", "participant"]
    },
    "phase": {
      "type": "string",
      "enum": [
        "idle",
        "bundle_ready",
        "reconciling",
        "bootstrapping",
        "editing",
        "verifying",
        "publishing",
        "blocked",
        "released"
      ]
    },
    "state": {
      "type": "string",
      "enum": ["active", "released", "expired", "quarantined"]
    },
    "lease_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_heartbeat_at": {
      "type": "string",
      "format": "date-time"
    },
    "lease_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "claimed_commit_units": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claimed_scope_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claimed_hot_roots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "claimed_resource_claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource_claim"
      }
    },
    "quarantine_reason": {
      "type": "string"
    }
  },
  "$defs": {
    "resource_claim": {
      "type": "object",
      "required": ["resource", "mode"],
      "properties": {
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["shared", "exclusive"]
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "lease_record": {
      "$ref": "#"
    },
    "acquire_request": {
      "type": "object",
      "required": ["repository", "task_id", "session_id", "holder_agent_id", "mode"],
      "properties": {
        "repository": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "holder_agent_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["writer", "observer", "participant"]
        },
        "claimed_commit_units": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claimed_scope_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claimed_hot_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claimed_resource_claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_claim"
          }
        }
      },
      "additionalProperties": false
    },
    "heartbeat_request": {
      "type": "object",
      "required": ["repository", "task_id", "session_id", "phase"],
      "properties": {
        "repository": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "release_request": {
      "type": "object",
      "required": ["repository", "task_id", "session_id", "reason"],
      "properties": {
        "repository": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "release_response": {
      "type": "object",
      "required": ["ok", "state"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["released", "expired", "quarantined"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
