{
  "version": 1,
  "conflict_classes": ["parallel-safe", "serial", "integration-hot"],
  "admission_modes": ["standard", "landing-exclusive", "global-exclusive"],
  "verification_classes": ["cheap", "affected-typecheck", "full-build-sensitive"],
  "admission_sources": [
    "serialized_scope_keys",
    "resource_claims",
    "hot_root_paths",
    "admission_mode",
    "commit_units"
  ],
  "verification_source": "allowed_files",
  "commit_units_required": true,
  "serialized_scope_key_by_scope_gate_key": {
    "api": "api",
    "app": "app_shell",
    "agent-runner": "worker_runtime",
    "agent-session-runtime": "worker_runtime",
    "command-surface": "command_surface_governance",
    "delivery-ci": "delivery_ci_control_plane",
    "docs-index": "docs_index_governance",
    "documentation-system": "documentation_system_governance",
    "generated-tooling": "generated_tooling",
    "gitops": "gitops_control_plane",
    "ops": "ops_control_plane",
    "platform-admin": "platform_admin",
    "publish": "publish_control_plane",
    "public-docs": "public_docs",
    "repo": "repo_control_plane",
    "repo-governance": "repo_governance",
    "repo-policy": "repo_policy_engine",
    "repoctl": "repoctl_control_plane",
    "scripts": "script_runtime_control_plane",
    "task-governance": "task_governance_control_plane",
    "worker": "worker_runtime",
    "worktree-runtime": "developer_runtime"
  },
  "implementation_owner_roots": ["apps", "apps-oss", "packages", "domains", "processes"],
  "ops_roots": ["tools", "scripts", "docs", "platform", ".github"],
  "repo_root_files": [
    "package.json",
    "bun.lock",
    "yarn.lock",
    "package-lock.json",
    "tsconfig.json",
    "tsconfig.base.json",
    "biome.json",
    "biome.jsonc",
    "turbo.json",
    "Cargo.toml",
    "Cargo.lock"
  ],
  "hot_root_patterns": [
    "package.json",
    "bun.lock",
    "tsconfig.base.json",
    "turbo.json",
    "docs/contracts/governance/**",
    "platform/dev/hooks/**",
    "platform/delivery/ci/**",
    "packages/*/package.json",
    "packages/*/src/index.ts",
    "packages/*/src/index.tsx",
    "packages/*/index.ts",
    "packages/*/index.tsx"
  ],
  "full_build_sensitive_patterns": [
    "package.json",
    "bun.lock",
    "tsconfig.base.json",
    "turbo.json",
    "docs/contracts/governance/**",
    "platform/dev/hooks/**",
    "platform/delivery/ci/**",
    "packages/*/package.json",
    "packages/*/src/index.ts",
    "packages/*/src/index.tsx",
    "packages/*/index.ts",
    "packages/*/index.tsx",
    "platform/dev/local/**",
    "platform/dev/worktree/**",
    "platform/delivery/testing/**",
    "tools/orchestrator/pr/**",
    "tools/apps/task/**",
    "scripts/check-local-pre-push-contract.ts",
    "tools/core/task-scope.ts"
  ]
}
