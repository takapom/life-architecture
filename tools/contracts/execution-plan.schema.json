{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omta.dev/tools/contracts/execution-plan.schema.json",
  "title": "OMTA Orchestrator Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "base_branch",
    "max_workers",
    "merge_mode",
    "merge_queue",
    "cleanup",
    "queue_strategy",
    "require_passing_tests",
    "require_traceability",
    "require_acceptance_checks",
    "issue_tracking",
    "source_items",
    "issue_map",
    "deferred_items",
    "nodes"
  ],
  "properties": {
    "base_branch": {
      "type": "string",
      "minLength": 1
    },
    "max_workers": {
      "type": "integer",
      "minimum": 1
    },
    "merge_mode": {
      "const": "remote-pr"
    },
    "merge_queue": {
      "type": "boolean"
    },
    "cleanup": {
      "type": "boolean"
    },
    "queue_strategy": {
      "const": "dag_priority"
    },
    "require_passing_tests": {
      "type": "boolean"
    },
    "require_traceability": {
      "type": "boolean"
    },
    "require_acceptance_checks": {
      "type": "boolean"
    },
    "issue_tracking": {
      "$ref": "#/$defs/issueTracking"
    },
    "source_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceItem"
      }
    },
    "issue_map": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/githubIssueUrl"
      }
    },
    "deferred_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deferredItem"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "githubIssueUrl": {
      "type": "string",
      "pattern": "^https://github\\.com/[^/]+/[^/]+/issues/[1-9][0-9]*$"
    },
    "issueTracking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "repository",
        "node_issue_mode",
        "progress_issue_number",
        "progress_issue_url"
      ],
      "properties": {
        "strategy": {
          "const": "remote-github-sot"
        },
        "repository": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "node_issue_mode": {
          "const": "per-node"
        },
        "progress_issue_number": {
          "type": "integer",
          "minimum": 0
        },
        "progress_issue_url": {
          "type": "string",
          "pattern": "^$|^https://github\\.com/[^/]+/[^/]+/issues/[1-9][0-9]*$"
        }
      }
    },
    "sourceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "verdict", "summary", "github_issue"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "enum": ["valid", "already-fixed", "invalid", "pending"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "github_issue": {
          "$ref": "#/$defs/githubIssueUrl"
        },
        "parent_issue_number": {
          "type": "integer",
          "minimum": 1
        },
        "parent_issue_url": {
          "$ref": "#/$defs/githubIssueUrl"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["parent_issue_number"]
          },
          "then": {
            "required": ["parent_issue_url"]
          }
        },
        {
          "if": {
            "required": ["parent_issue_url"]
          },
          "then": {
            "required": ["parent_issue_number"]
          }
        }
      ]
    },
    "deferredItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "taskScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_bucket",
        "owner_buckets",
        "conflict_class",
        "admission_mode",
        "global_invariant",
        "unfreeze_condition",
        "verification_class",
        "scope_gate_keys",
        "serialized_scope_keys",
        "hot_root_paths",
        "resource_claims"
      ],
      "properties": {
        "owner_bucket": {
          "type": "string",
          "minLength": 1
        },
        "owner_buckets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "conflict_class": {
          "enum": ["parallel-safe", "serial", "integration-hot"]
        },
        "admission_mode": {
          "enum": ["standard", "landing-exclusive", "global-exclusive"]
        },
        "global_invariant": {
          "type": "string"
        },
        "unfreeze_condition": {
          "type": "string"
        },
        "verification_class": {
          "enum": ["cheap", "affected-typecheck", "full-build-sensitive"]
        },
        "scope_gate_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "serialized_scope_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "hot_root_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resource_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode", "resource"],
            "properties": {
              "mode": {
                "enum": ["exclusive", "shared-read", "shared-write-forbidden"]
              },
              "resource": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "issue_node_id",
        "branch",
        "priority",
        "deps",
        "github_issue",
        "scope",
        "allowed_files",
        "commit_units",
        "non_goals",
        "acceptance_checks",
        "tests",
        "covers",
        "instructions",
        "task_scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "issue_node_id": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "github_issue": {
          "$ref": "#/$defs/githubIssueUrl"
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "allowed_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commit_units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "covers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "instructions": {
          "type": "string",
          "minLength": 1
        },
        "task_scope": {
          "$ref": "#/$defs/taskScope"
        }
      }
    }
  }
}
